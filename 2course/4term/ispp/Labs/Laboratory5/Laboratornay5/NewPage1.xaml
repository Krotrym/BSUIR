<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Laboratornay5.NewPage1"
             Title="NewPage1"
             Loaded="ContentPage_Loaded">
    <VerticalStackLayout>



        <Picker SelectedIndexChanged="LoadElements"
        x:Name="MyPicker">
        </Picker>

        <CollectionView x:Name="LessonsList"
                Margin="0,20,0,0">
            <CollectionView.ItemTemplate>
                <DataTemplate>
                    <Border>
                        <Label Text="{Binding Title}"
                       TextColor="Black" />
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>
        </CollectionView>


    </VerticalStackLayout>
</ContentPage>